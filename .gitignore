.venv/
__pycache__/
*.pyc
.DS_Store
cache/

# Raw imagery is too large for the repo (see data/readme.md); OSM cache and
# filtered outputs are regenerated by running main.py. annotated_bike_lanes
# and textures are small hand-picked data though, so keep those tracked --
# the texture crops in particular *are* the texture detectors, since there
# are no trained weights to fall back on, so a clone without them can't run
# that half of the pipeline at all.
data/osm/
data/output/
data/detections/
data/training/

# YOLO checkpoints (auto-downloaded) and training run output
*.pt
runs/

.claude
